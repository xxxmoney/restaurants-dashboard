{
  "name": "backend",
  "scripts": {
    "dev": "wrangler dev  --test-scheduled",
    "deploy": "wrangler deploy --minify",
    "test": "vitest",
    "auth:generate": "npx --yes @better-auth/cli@latest generate --config src/auth/index.ts --output src/db/auth.schema.ts -y",
    "auth:format": "npx --yes prettier --write src/db/auth.schema.ts",
    "auth:update": "npm run auth:generate && npm run auth:format",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "wrangler d1 migrations apply restaurants-dashboard-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply restaurants-dashboard-db --remote",
    "db:studio:dev": "drizzle-kit studio",
    "db:studio:prod": "NODE_ENV=production drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.8",
    "@google/generative-ai": "^0.21.0",
    "better-auth": "1.6.11",
    "better-auth-cloudflare": "^0.3.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.12",
    "luxon": "^3.5.0",
    "pdfjs-serverless": "^0.7.0",
    "string-format": "^2.0.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/jsdom": "^21.1.7",
    "@types/luxon": "^3.4.2",
    "@types/string-format": "^2.0.3",
    "better-sqlite3": "^12.10.1",
    "drizzle-kit": "^0.31.10",
    "expect-matchers": "^1.2.0",
    "vitest": "2.1.8",
    "wrangler": "^3.99.0"
  },
  "overrides": {
    "vite": "^5.0.0",
    "@better-auth/sso": "1.6.11",
    "@better-auth/utils": "0.4.1"
  }
}
